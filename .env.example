# ============================================================
# Validar Print API - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=validar_print
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Segurança - token para acessar o painel admin
ADMIN_TOKEN=troque_este_token_seguro_admin

# Timeout de heartbeat em segundos (máquina considerada offline após X segundos sem heartbeat)
HEARTBEAT_TIMEOUT_SECONDS=120

# URL base da API (usada para referência nos logs)
API_BASE_URL=http://localhost:3000
